# Copy this to /etc/token-poker.env on the server and fill in your domain.
# This file (the .example) is safe to commit; the real /etc/token-poker.env is NOT
# in the repo and holds your production config. Keep it 0640 root:poker.
#
#   sudo cp deploy/token-poker.env.example /etc/token-poker.env
#   sudo nano /etc/token-poker.env          # set DOMAIN + CORS_ORIGIN
#   sudo chown root:poker /etc/token-poker.env && sudo chmod 640 /etc/token-poker.env

NODE_ENV=production

# Node listens only on localhost; Caddy is the sole public surface.
HOST=127.0.0.1
PORT=3000

# Node serves the built web/dist itself? No — Caddy serves the static files,
# so leave this off in this deployment.
SERVE_STATIC=0

# Your public origin. MUST be the exact scheme+host (no trailing slash).
# The server REFUSES to start if this is "*" in production.
# Real domain:   https://poker.example.com
# Free fallback: https://5-75-1-2.sslip.io   (replace with your IP, dashes for dots)
# (Caddy's matching DOMAIN is set separately, on the Caddy service — see the guide.)
CORS_ORIGIN=https://CHANGE-ME.example.com

# Behind Caddy, trust X-Forwarded-For so per-IP limits use the real client IP.
TRUST_PROXY=1

# Persistent SQLite path (inside the unit's ReadWritePaths).
DB_PATH=/opt/token-poker/server/data/rooms.sqlite

# --- Optional tuning (defaults shown; uncomment to override) ---
# IDLE_TTL_MS=14400000
# MAX_TTL_MS=86400000
# MAX_ROOMS_PER_IP=20
# MAX_SOCKETS_PER_IP=30
